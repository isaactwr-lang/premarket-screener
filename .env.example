# Trading Bot Configuration
# 
# Store your sensitive credentials here (NOT in version control)
# This file is in .gitignore for security

# Alpaca API Credentials (from your paper trading account)
# Get these from: https://app.alpaca.markets → Account → Settings → API Keys
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here

# Data Source: "alpaca" or "yfinance" or "mock"
DATA_SOURCE=mock

# Trading Environment: "paper" or "live"
TRADING_ENV=paper
